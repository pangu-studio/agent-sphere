#include "version.h"
#include <winver.h>

VS_VERSION_INFO VERSIONINFO
FILEVERSION    AGENTSPHERE_VERSION_RC
PRODUCTVERSION AGENTSPHERE_VERSION_RC
FILEFLAGSMASK  VS_FFI_FILEFLAGSMASK
#ifdef _DEBUG
FILEFLAGS      VS_FF_DEBUG
#else
FILEFLAGS      0
#endif
FILEOS         VOS_NT_WINDOWS32
FILETYPE       VFT_APP
FILESUBTYPE    VFT2_UNKNOWN
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904B0"
        BEGIN
            VALUE "CompanyName",      AGENTSPHERE_COMPANY_NAME
            VALUE "FileDescription",  "AgentSphere VM Runtime"
            VALUE "FileVersion",      AGENTSPHERE_VERSION_STR
            VALUE "InternalName",     "agentsphere-vm-runtime"
            VALUE "LegalCopyright",   AGENTSPHERE_COPYRIGHT
            VALUE "OriginalFilename", "agentsphere-vm-runtime.exe"
            VALUE "ProductName",      AGENTSPHERE_PRODUCT_NAME
            VALUE "ProductVersion",   AGENTSPHERE_VERSION_STR
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x0409, 1200
    END
END
